{
  "name": "captains-log",
  "version": "1.1.0",
  "description": "TOP Captain's Log - A modern IT Department Daily Tracker for documenting daily activities and maintaining comprehensive work records",
  "author": "TOP Captain's Log Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/captains-log.git"
  },
  "keywords": [
    "daily-log",
    "it-tracker",
    "developer-journal",
    "work-log",
    "nextjs",
    "react",
    "typescript"
  ],
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "BROWSERSLIST_IGNORE_OLD_DATA=true BASELINE_BROWSER_MAPPING_IGNORE_OLD_DATA=true next build --webpack",
    "start": "node --trace-deprecation node_modules/.bin/next start -p 5002",
    "start:default": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out node_modules",
    "prepare": "husky install || true",
    "test": "jest",
    "test:is-admin": "node scripts/test-is-admin-function.js",
    "seed:test-users": "ts-node scripts/seed-and-test-users.ts",
    "test:is-admin-as-user": "ts-node scripts/test-is-admin-as-user.ts",
    "check:account": "ts-node scripts/check-my-account.ts",
    "check:account:simple": "node scripts/check-account-simple.js",
    "check:marketing-call-kpis": "node scripts/check-marketing-call-kpis.js",
    "check:marketing-unspecified": "node scripts/check-marketing-unspecified.js",
    "reset:role-question-scope": "NODE_ENV=development ts-node scripts/reset-role-question-scope.ts",
    "reset:dev-database": "NODE_ENV=development ts-node scripts/reset-dev-database.ts",
    "report:scope-entry-kinds-migration": "NODE_ENV=development ts-node scripts/report-scope-entry-kinds-migration.ts"
  },
